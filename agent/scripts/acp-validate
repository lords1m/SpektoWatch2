#!/usr/bin/env sh
set -eu

root="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
missing=0

required='
AGENT.md
agent/manifest.yaml
agent/progress.yaml
agent/design/requirements.md
agent/design/acp-integration.md
agent/design/project-draft.md
agent/design/spektowatch-field-engineering-design.md
agent/drafts/spektowatch-project.draft.md
agent/clarifications/spektowatch-project.clarification.md
agent/commands/acp.status.md
agent/commands/acp.proceed.md
agent/commands/acp.init.md
agent/commands/acp.validate.md
agent/commands/acp.report.md
agent/commands/acp.sync.md
agent/commands/acp.clarification-create.md
agent/commands/acp.clarification-address.md
agent/commands/acp.design-create.md
agent/commands/acp.plan.md
agent/patterns/swiftui-audio-pipeline.md
'

for path in $required; do
  if [ ! -f "$root/$path" ]; then
    echo "missing: $path"
    missing=1
  fi
done

# --- Glob check: every milestone and its task directory must exist ---
for milestone_file in "$root"/agent/milestones/milestone-*.md; do
  [ -f "$milestone_file" ] || continue
  milestone_name="$(basename "$milestone_file" .md)"
  task_dir="$root/agent/tasks/$milestone_name"

  if [ ! -d "$task_dir" ]; then
    echo "missing task directory: agent/tasks/$milestone_name"
    missing=1
  fi
done

# --- Cross-reference check: every `file:` entry in progress.yaml must exist ---
# Only match file: values that look like repo paths (start with "agent/" or "AGENT").
# Both block-style and flow-style YAML are handled.
awk '
  # Block style: leading whitespace then "file: agent/..."
  /^[[:space:]]*file:[[:space:]]*(agent\/|AGENT)/ {
    sub(/^[[:space:]]*file:[[:space:]]*/, "")
    sub(/[[:space:]]*$/, "")
    if (length > 0) print
    next
  }
  # Flow style: "file: agent/..." inside a { } line
  /file:[[:space:]]*(agent\/|AGENT)/ {
    line = $0
    while (match(line, /file:[[:space:]]+(agent\/|AGENT)[^,} ]*/)) {
      chunk = substr(line, RSTART, RLENGTH)
      sub(/^file:[[:space:]]+/, "", chunk)
      gsub(/[[:space:]]+$/, "", chunk)
      if (length(chunk) > 0) print chunk
      line = substr(line, RSTART + RLENGTH)
    }
  }
' "$root/agent/progress.yaml" | sort -u | while IFS= read -r relpath; do
  if [ -n "$relpath" ] && [ ! -f "$root/$relpath" ]; then
    echo "progress.yaml references missing file: $relpath"
    # Signal failure via a temp flag file (subshell can't set outer var)
    touch "$root/.acp-validate-missing-$$"
  fi
done

if [ -f "$root/.acp-validate-missing-$$" ]; then
  rm -f "$root/.acp-validate-missing-$$"
  missing=1
fi

# --- Pointer-resolution check for current task ---
current_milestone_yaml="$(awk -F': ' '/^current_milestone:/ { print $2 }' "$root/agent/progress.yaml")"
current_task="$(awk -F': ' '/^current_task:/ { print $2 }' "$root/agent/progress.yaml")"

if [ -z "$current_milestone_yaml" ]; then
  echo "missing current_milestone in agent/progress.yaml"
  exit 1
fi
if [ -z "$current_task" ]; then
  echo "missing current_task in agent/progress.yaml"
  exit 1
fi

case "$current_milestone_yaml" in
  M1)  task_dir="agent/tasks/milestone-1-acp-bootstrap" ;;
  M2)  task_dir="agent/tasks/milestone-2-performance-stabilization-watch-architecture" ;;
  M3)  task_dir="agent/tasks/milestone-3-dashboard-and-recording-polish" ;;
  M4)  task_dir="agent/tasks/milestone-4-export-and-reporting" ;;
  M5)  task_dir="agent/tasks/milestone-5-watch-complications" ;;
  M6)  task_dir="agent/tasks/milestone-6-code-audit-remediation" ;;
  M7)  task_dir="agent/tasks/milestone-7-xcode-cloud-snapshot-testing" ;;
  M8)  task_dir="agent/tasks/milestone-8-widget-sizing-refactor" ;;
  M9)  task_dir="agent/tasks/milestone-9-widget-audit" ;;
  M10) task_dir="agent/tasks/milestone-10-ios-standalone-widgets" ;;
  M11) task_dir="agent/tasks/milestone-11-tone-generator-piano-input" ;;
  M12) task_dir="agent/tasks/milestone-12-liquid-glass-redesign" ;;
  M13) task_dir="agent/tasks/milestone-13-architecture-hygiene" ;;
  M14) task_dir="agent/tasks/milestone-14-performance-centralization" ;;
  M15) task_dir="agent/tasks/milestone-15-critical-stability-correctness" ;;
  M16) task_dir="agent/tasks/milestone-16-watch-connectivity-hardening" ;;
  M17) task_dir="agent/tasks/milestone-17-swiftui-lifecycle-performance" ;;
  M18) task_dir="agent/tasks/milestone-18-test-tooling-debt" ;;
  M19) task_dir="agent/tasks/milestone-19-instruments-trace-perf-fixes" ;;
  M20) task_dir="agent/tasks/milestone-20-live-activities" ;;
  M21) task_dir="agent/tasks/milestone-21-watch-standalone" ;;
  *)   task_dir="agent/tasks/$current_milestone_yaml" ;;
esac

task_path="$root/$task_dir/$current_task.md"
if [ ! -f "$task_path" ]; then
  echo "current_task does not resolve: $current_task"
  exit 1
fi

if [ "$missing" -ne 0 ]; then
  exit 1
fi

echo "ACP validation passed"
